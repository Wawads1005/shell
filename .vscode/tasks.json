{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "Build",
      "command": "/usr/bin/gcc",
      "args": ["-Iinclude", "src/*.c", "-o", "main.exe"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ],
  "version": "2.0.0"
}
